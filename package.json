{
  "name": "llm-model-manager",
  "version": "1.1.0",
  "description": "Electron tool to check if a model is available",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electronmon .",
    "dist": "electron-builder --publish never",
    "dist:mac": "electron-builder --mac dmg zip --publish never",
    "dist:win": "electron-builder --win nsis portable --publish never",
    "dist:linux": "electron-builder --linux AppImage tar.gz --publish never"
  },
  "keywords": [
    "electron",
    "llm-model-manager"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@harnessgg/electron": "^0.1.0",
    "electron": "^28.0.0",
    "electron-builder": "^26.0.12",
    "electronmon": "^2.0.4"
  },
  "dependencies": {
    "highlight.js": "^11.11.1",
    "marked": "^17.0.5"
  },
  "build": {
    "appId": "com.jzj.modelchecker",
    "productName": "LLM Model Manager",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "src/**/*",
      "package.json",
      "node_modules/**/*"
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.developer-tools"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "tar.gz"
      ],
      "category": "Development"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "jzj1993",
        "repo": "llm-model-manager"
      }
    ]
  }
}
